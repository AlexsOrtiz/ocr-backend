# Opcional: puerto del servidor (por defecto uvicorn usa 8000)
# PORT=8000

# Orígenes CORS permitidos (separados por coma). El front en local suele usar 5173.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# OpenAI (solo para la capa de visión OCR). Obtén la key en https://platform.openai.com/api-keys
# Copia este archivo a .env y pon aquí tu key real ( .env no se sube a git )
# OPENAI_API_KEY=sk-proj-...
